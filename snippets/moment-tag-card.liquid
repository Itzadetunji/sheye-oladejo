{% comment %}
  Moment card driven by section-provided values.
  @param title {String} Card title
  @param tag {String} Product tag to filter by
  @param card_image {MediaImage} Card image
  @param section_id {String}
  @param card_index {Number}
  @param lazy_load {Boolean}
  @param skip_styles {Boolean}
{% endcomment %}
{%- liquid
  assign lazy_load = lazy_load | default: true
  assign skip_styles = skip_styles | default: false
  assign uid = section_id | append: '-moment-' | append: card_index

  assign title = title | default: '' | strip
  assign filter_tag = tag | default: title
  assign filter_tag = filter_tag | strip

  assign has_image = false
  if card_image != blank
    assign has_image = true
  endif

  assign card_url = routes.all_products_collection_url
  if filter_tag != blank
    assign tag_handle = filter_tag | replace: '_', '-' | handleize
    assign card_url = card_url | append: '/' | append: tag_handle
  endif
-%}
{%- unless skip_styles -%}
  {{ 'component-card.css' | asset_url | stylesheet_tag }}
  {{ 'component-moment-card.css' | asset_url | stylesheet_tag }}
{%- endunless -%}
<div class="card-wrapper product-card-wrapper underline-links-hover moment-card-wrapper">
  <div
    class="
      card card--{{ settings.card_style }}
      moment-card
      moment-tag-card
      card--media
      card--extend-height
      card--stacked-product
      {% if settings.card_style == 'card' %}color-{{ settings.card_color_scheme }} gradient{% endif %}
    "
    style="--ratio-percent: 133.333%;"
  >
    <div
      class="card__inner ratio{% if settings.card_style == 'standard' %} color-{{ settings.card_color_scheme }} gradient{% endif %}"
      style="--ratio-percent: 133.333%;"
    >
      {%- if has_image -%}
        <div class="card__media color-{{ settings.card_color_scheme }} gradient">
          <div class="media media--transparent">
            {% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
            <img
              srcset="
                {%- if card_image.width >= 165 -%}{{ card_image | image_url: width: 165 }} 165w,{%- endif -%}
                {%- if card_image.width >= 360 -%}{{ card_image | image_url: width: 360 }} 360w,{%- endif -%}
                {%- if card_image.width >= 533 -%}{{ card_image | image_url: width: 533 }} 533w,{%- endif -%}
                {%- if card_image.width >= 720 -%}{{ card_image | image_url: width: 720 }} 720w,{%- endif -%}
                {%- if card_image.width >= 940 -%}{{ card_image | image_url: width: 940 }} 940w,{%- endif -%}
                {{ card_image | image_url }} {{ card_image.width }}w
              "
              src="{{ card_image | image_url: width: 533 }}"
              sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 768px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
              alt="{{ card_image.alt | default: title | escape }}"
              class="motion-reduce"
              {% if lazy_load %}
                loading="lazy"
              {% endif %}
              width="{{ card_image.width }}"
              height="{{ card_image.height }}"
            >
            {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}
          </div>
        </div>
      {%- else -%}
        <div class="card__media color-{{ settings.card_color_scheme }} gradient">
          <div class="media media--transparent">
            <div class="moment-card-carousel__slide moment-card-carousel__slide--placeholder">
              {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          </div>
        </div>
      {%- endif -%}
      <div class="card__content">
        <div class="card__information">
          <h3 class="card__heading">
            <a
              href="{{ card_url }}"
              id="StandardCardNoMediaLink-{{ uid }}"
              class="full-unstyled-link card__heading-link"
              aria-label="{{ title | escape }}"
            >
              <span class="card__heading-line card__heading-line--title">{{ title | upcase }}</span>
              <span class="card__heading-line card__heading-line--price"></span>
            </a>
          </h3>
        </div>
        <div class="card__badge {{ settings.badge_position }}"></div>
      </div>
      <div class="card-hover-info">
        <h3 class="card-hover-info__title">
          <a href="{{ card_url }}" class="full-unstyled-link" aria-label="{{ title | escape }}">
            {{ title | upcase }}
          </a>
        </h3>
        <p class="card-hover-info__price"></p>
      </div>
    </div>

    <div class="card__content">
      <div class="card__information">
        <h3
          class="card__heading{% if has_image or settings.card_style == 'standard' %} h5{% endif %}"
          {% if has_image or settings.card_style == 'card' %}
            id="title-{{ uid }}"
          {% endif %}
        >
          <a
            href="{{ card_url }}"
            id="CardLink-{{ uid }}"
            class="full-unstyled-link card__heading-link"
            aria-label="{{ title | escape }}"
          >
            <span class="card__heading-line card__heading-line--title">{{ title | upcase }}</span>
            <span class="card__heading-line card__heading-line--price"></span>
          </a>
        </h3>
      </div>
      <div class="card__badge {{ settings.badge_position }}"></div>
    </div>
  </div>
</div>

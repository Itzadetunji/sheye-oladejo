<div class="video-gallery-component{% if wrapper_class != blank %} {{ wrapper_class }}{% endif %}" data-video-gallery-component>
  <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width">
    {%- if title != blank -%}
      <h2 class="title inline-richtext video-gallery-component__title {{ heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ title }}
      </h2>
    {%- endif -%}
  </div>

  <div class="page-width">
    <div class="video-gallery-component__grid">
      {%- for i in (1..3) -%}
        {%- liquid
          assign card_video = blank
          assign card_label = 'Play gallery video '
          case i
            when 1
              assign card_video = video_1
            when 2
              assign card_video = video_2
            when 3
              assign card_video = video_3
          endcase
        -%}
        <button
          type="button"
          class="video-gallery-component__card"
          data-video-card
          data-video-index="{{ forloop.index0 }}"
          aria-label="{{ card_label }}{{ i }}"
        >
          {%- if card_video != blank -%}
            {{
              card_video
              | video_tag:
                image_size: '900x',
                autoplay: false,
                loop: false,
                muted: true,
                controls: false,
                playsinline: true
            }}
          {%- else -%}
            <div class="video-gallery-component__placeholder">
              {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </button>
      {%- endfor -%}
    </div>
  </div>
</div>

{% comment %}
  Single-image autoplay carousel for appointment-couture tiles.

  Accepts:
    - slides: blocks for the carousel (up to 5 from section schema)
    - carousel_uid: unique id suffix
    - interval_ms: autoplay interval in ms (defaults to 3000)
    - button_text: CTA text
    - button_link: CTA URL
    - default_button_text: fallback CTA text
    - default_button_link: fallback CTA URL
    - fallback_image: optional image used when no slides exist
{% endcomment %}

{%- assign interval_ms = interval_ms | default: 3000 -%}
{%- assign cta_text = button_text | default: default_button_text -%}
{%- assign cta_link = button_link | default: default_button_link -%}
{%- assign has_slides = false -%}
{%- if slides != blank and slides.size > 0 -%}
  {%- assign has_slides = true -%}
{%- endif -%}

<div
  class="book-appointment-or-couture__hero appointment-couture-carousel"
  data-appointment-slider-carousel
  data-carousel-interval="{{ interval_ms }}"
  id="AppointmentSliderCarousel--{{ carousel_uid }}"
>
  <div class="appointment-couture-carousel__viewport" aria-live="off">
    <div class="appointment-couture-carousel__track" data-carousel-track>
      {%- if has_slides -%}
        {%- for block in slides limit: 5 -%}
          {%- assign ph_i = forloop.index0 | modulo: 3 -%}
          <div class="appointment-couture-carousel__slide" data-carousel-slide {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  class: 'appointment-couture-carousel__img',
                  sizes: '50vw',
                  widths: '375, 550, 750, 1100, 1200'
              }}
            {%- else -%}
              <div class="appointment-couture-carousel__placeholder">
                {%- case ph_i -%}
                  {%- when 0 -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- when 1 -%}
                    {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- else -%}
                    {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endcase -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="appointment-couture-carousel__slide" data-carousel-slide>
          {%- if fallback_image != blank -%}
            {{
              fallback_image
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                class: 'appointment-couture-carousel__img',
                sizes: '50vw',
                widths: '375, 550, 750, 1100, 1200'
            }}
          {%- else -%}
            <div class="appointment-couture-carousel__placeholder">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <a
    href="{{ cta_link }}"
    class="appointment-couture-carousel__hitarea"
    aria-label="{{ cta_text | escape }}"
  ></a>

  <a href="{{ cta_link }}" class="appointment-couture-carousel__btn button">
    {{ cta_text | escape }}
  </a>
</div>

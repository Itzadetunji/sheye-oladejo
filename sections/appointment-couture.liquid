<script src="{{ 'section-appointment-couture-carousel.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign left_carousel_blocks = section.blocks | where: 'type', 'left_carousel_slide'
  assign right_carousel_blocks = section.blocks | where: 'type', 'right_carousel_slide'
  assign carousel_left_uid = section.id | append: '-left'
  assign carousel_right_uid = section.id | append: '-right'
-%}

<section
  class="book-appointment-or-couture book-appointment-or-couture--{{ section.id }}"
  aria-label="{{ section.settings.section_heading | default: 'Book appointment or couture' | escape }}"
>
  <div class="book-appointment-or-couture__grid">
    <div class="book-appointment-or-couture__tile book-appointment-or-couture__tile--left">
      <div class="book-appointment-or-couture__hero">
        {%- if section.settings.image_left != blank -%}
          {{
            section.settings.image_left
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              class: 'book-appointment-or-couture__img',
              sizes: '50vw',
              widths: '375, 550, 750, 1100, 1200'
          }}
        {%- else -%}
          <div class="book-appointment-or-couture__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
        <a
          href="{{ section.settings.left_button_link | default: '/shop' }}"
          class="book-appointment-or-couture__btn button"
        >
          {{ section.settings.left_button_text | default: 'BESPOKE SERVICES' | escape }}
        </a>
      </div>
      {%- render 'appointment-couture-carousel',
        slides: left_carousel_blocks,
        carousel_uid: carousel_left_uid,
        interval_ms: 2000
      -%}
    </div>

    <div class="book-appointment-or-couture__tile book-appointment-or-couture__tile--right">
      <div class="book-appointment-or-couture__hero">
        {%- if section.settings.image_right != blank -%}
          {{
            section.settings.image_right
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              class: 'book-appointment-or-couture__img',
              sizes: '50vw',
              widths: '375, 550, 750, 1100, 1200'
          }}
        {%- else -%}
          <div class="book-appointment-or-couture__placeholder">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
        <a
          href="{{ section.settings.right_button_link | default: '/book-consultation' }}"
          class="book-appointment-or-couture__btn button"
        >
          {{ section.settings.right_button_text | default: 'BRIDAL COUTURE' | escape }}
        </a>
      </div>
      {%- render 'appointment-couture-carousel',
        slides: right_carousel_blocks,
        carousel_uid: carousel_right_uid,
        interval_ms: 3000
      -%}
    </div>
  </div>
</section>

{%- style -%}
  .book-appointment-or-couture--{{ section.id }} {
    --book-appointment-bg: {{ section.settings.background_color }};
  }

  .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__tile {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
  }

  .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__hero {
    position: relative;
    min-height: 22rem;
    overflow: hidden;
    flex: 0 0 auto;
  }

  .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__btn {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    text-decoration: none;
    letter-spacing: 0.1em;
    white-space: nowrap;
    background-color: #000;
    color: #fff;
    border-color: #000;
  }

  .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__btn:hover {
    background-color: #333;
    color: #fff;
    border-color: #333;
  }

  @media screen and (max-width: 749px) {
    .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__btn {
      padding: 0.8rem 1.2rem;
      font-size: 1rem;
      min-height: auto;
    }
  }

  .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    inset: 0;
  }

  .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__placeholder {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.12);
  }

  .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.45;
    display: block;
  }

  @media screen and (min-width: 750px) {
    .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__grid {
      grid-template-columns: 1fr 1fr;
    }

    .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__hero {
      min-height: clamp(22rem, 42vw, 36rem);
    }
  }
{%- endstyle -%}

<style>
  /* Shared carousel (both cards) — flex row: prev | viewport | next; gap 1rem */
  .appointment-couture-carousel {
    width: 100%;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    box-sizing: border-box;
  }

  .appointment-couture-carousel__viewport {
    container-type: inline-size;
    container-name: appointment-couture-carousel;
    flex: 1 1 auto;
    min-width: 0;
    min-height: 480px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .appointment-couture-carousel__track {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 1rem;
    flex: 1 1 auto;
    transition: transform 0.35s ease;
    will-change: transform;
  }

  /* Desktop: 2 slides per view (width = carousel viewport via cqi) */
  .appointment-couture-carousel__slide {
    flex: 0 0 calc((100cqi - 1rem) / 2);
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-self: stretch;
  }

  /* ≤1024px: one slide per view; >1024px: two slides (default above) */
  @media screen and (max-width: 1024px) {
    .appointment-couture-carousel__slide {
      flex: 0 0 100cqi;
    }
  }

  .appointment-couture-carousel__media {
    position: relative;
    width: 100%;
    min-height: 480px;
    aspect-ratio: 3 / 4;
    border-radius: 0.25rem;
    flex-shrink: 0;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
  }

  .appointment-couture-carousel__media .appointment-couture-carousel__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .appointment-couture-carousel__btn {
    flex: 0 0 auto;
    align-self: center;
    min-width: 2.5rem;
    min-height: 2.5rem;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: rgb(var(--color-foreground));
    border-radius: 0;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .appointment-couture-carousel__btn:hover:not(:disabled) {
    opacity: 0.65;
  }

  .appointment-couture-carousel__btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  @media screen and (max-width: 1024px) {
    .appointment-couture-carousel__media {
      min-height: 480px;
    }
  }
</style>

{% schema %}
{
  "name": "Appointment & Couture",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading (for accessibility)",
      "default": "Book appointment or couture"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left image"
    },
    {
      "type": "text",
      "id": "left_button_text",
      "label": "Left button text",
      "default": "COUTURE"
    },
    {
      "type": "url",
      "id": "left_button_link",
      "label": "Left button link",
      "info": "Defaults to /shop if empty"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Right image"
    },
    {
      "type": "text",
      "id": "right_button_text",
      "label": "Right button text",
      "default": "READY TO WEAR"
    },
    {
      "type": "url",
      "id": "right_button_link",
      "label": "Right button link",
      "info": "Defaults to /book-consultation if empty"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F3EDE8"
    }
  ],
  "blocks": [
    {
      "type": "left_carousel_slide",
      "name": "Left carousel slide",
      "settings": []
    },
    {
      "type": "right_carousel_slide",
      "name": "Right carousel slide",
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Appointment & Couture",
      "blocks": [
        { "type": "left_carousel_slide", "settings": {} },
        { "type": "left_carousel_slide", "settings": {} },
        { "type": "left_carousel_slide", "settings": {} },
        { "type": "left_carousel_slide", "settings": {} },
        { "type": "right_carousel_slide", "settings": {} },
        { "type": "right_carousel_slide", "settings": {} },
        { "type": "right_carousel_slide", "settings": {} },
        { "type": "right_carousel_slide", "settings": {} }
      ]
    }
  ]
}
{% endschema %}

<script src="{{ 'section-appointment-couture-carousel.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign left_carousel_blocks = section.blocks | where: 'type', 'left_carousel_slide'
  assign right_carousel_blocks = section.blocks | where: 'type', 'right_carousel_slide'
  assign carousel_left_uid = section.id | append: '-left'
  assign carousel_right_uid = section.id | append: '-right'
  assign left_carousel_delay_ms = 3000
  assign right_carousel_delay_ms = 3600
-%}

<section
  class="book-appointment-or-couture book-appointment-or-couture--{{ section.id }}"
  aria-label="{{ section.settings.section_heading | default: 'Book appointment or couture' | escape }}"
>
  <div class="page-width">
    <div class="book-appointment-or-couture__grid">
      {%- render 'appointment-couture-carousel',
        slides: left_carousel_blocks,
        carousel_uid: carousel_left_uid,
        button_text: section.settings.left_button_text,
        button_link: section.settings.left_button_link,
        default_button_text: 'BESPOKE SERVICES',
        default_button_link: '/shop',
        fallback_image: section.settings.image_left,
        interval_ms: left_carousel_delay_ms
      -%}

      {%- render 'appointment-couture-carousel',
        slides: right_carousel_blocks,
        carousel_uid: carousel_right_uid,
        button_text: section.settings.right_button_text,
        button_link: section.settings.right_button_link,
        default_button_text: 'BRIDAL COUTURE',
        default_button_link: '/book-consultation',
        fallback_image: section.settings.image_right,
        interval_ms: right_carousel_delay_ms
      -%}
    </div>
  </div>
</section>

{%- style -%}
  .book-appointment-or-couture--{{ section.id }} {
    --book-appointment-bg: {{ section.settings.background_color }};
    padding-bottom: 64px;
  }

  .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }


  .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__tile {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
  }

  .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    flex: 1 1 auto;
  }

  .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel__viewport {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel__track {
    display: flex;
    height: 100%;
    transition: transform 0.55s ease;
    will-change: transform;
  }

  .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel__slide {
    position: relative;
    flex: 0 0 100%;
    height: 100%;
  }

  .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel__btn {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    text-decoration: none;
    letter-spacing: 0.1em;
    white-space: nowrap;
    background-color: #000;
    color: #fff;
    border-color: #000;
  }

  .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel__hitarea {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: block;
  }

  .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel__btn:hover {
    background-color: #333;
    color: #fff;
    border-color: #333;
  }

  @media screen and (max-width: 639px) {
    .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel__btn {
      padding: 0.8rem 1.2rem;
      font-size: 1rem;
      min-height: auto;
    }
  }

  @media screen and (max-width: 1023px) {
    .book-appointment-or-couture--{{ section.id }} > .page-width {
      padding-left: 0 !important;
      padding-right: 0 !important;
    }
  }

  .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: absolute;
    inset: 0;
  }

  .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel__placeholder {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.12);
  }

  .book-appointment-or-couture--{{ section.id }} .appointment-couture-carousel__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.45;
    display: block;
  }

  @media screen and (min-width: 768px) {
    .book-appointment-or-couture--{{ section.id }} .book-appointment-or-couture__grid {
      grid-template-columns: 1fr 1fr;
    }

  }
{%- endstyle -%}

{% schema %}
{
  "name": "Appointment & Couture",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading (for accessibility)",
      "default": "Book appointment or couture"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left image"
    },
    {
      "type": "text",
      "id": "left_button_text",
      "label": "Left button text",
      "default": "COUTURE"
    },
    {
      "type": "url",
      "id": "left_button_link",
      "label": "Left button link",
      "info": "Defaults to /shop if empty"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Right image"
    },
    {
      "type": "text",
      "id": "right_button_text",
      "label": "Right button text",
      "default": "READY TO WEAR"
    },
    {
      "type": "url",
      "id": "right_button_link",
      "label": "Right button link",
      "info": "Defaults to /book-consultation if empty"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F3EDE8"
    }
  ],
  "blocks": [
    {
      "type": "left_carousel_slide",
      "name": "Left carousel slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "right_carousel_slide",
      "name": "Right carousel slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Appointment & Couture",
      "blocks": [
        { "type": "left_carousel_slide", "settings": {} },
        { "type": "left_carousel_slide", "settings": {} },
        { "type": "left_carousel_slide", "settings": {} },
        { "type": "left_carousel_slide", "settings": {} },
        { "type": "right_carousel_slide", "settings": {} },
        { "type": "right_carousel_slide", "settings": {} },
        { "type": "right_carousel_slide", "settings": {} },
        { "type": "right_carousel_slide", "settings": {} }
      ]
    }
  ]
}
{% endschema %}

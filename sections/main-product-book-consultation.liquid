{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign callout_heading = section.settings.callout_text | strip
  if callout_heading == blank
    assign callout_heading = 'Feel the Magic in Every Conversation'
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .book-consultation-{{ section.id }} {
    background: rgb(var(--color-background));
  }

  .book-consultation-{{ section.id }} .page-width {
    /* max-width: 90rem; */
    margin-inline: auto;
  }

  .book-consultation-{{ section.id }}__placeholder,
  .book-consultation-{{ section.id }} .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .book-consultation-{{ section.id }}__placeholder {
    background: rgba(var(--color-foreground), 0.06);
  }

  .book-consultation-{{ section.id }}__callout {
    min-height: 12rem;
    background: {{ settings.color_accent_porcelain | default: '#F3EDE8' }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .book-consultation-{{ section.id }}__callout-heading {
    margin: 0;
    font-size: clamp(1.9rem, 4.3vw, 3.5rem);
    font-family: "Times New Roman", Georgia, serif;
    font-style: italic;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    line-height: 1.2;
  }

  .book-consultation-{{ section.id }}__cluster {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .book-consultation-{{ section.id }}__cluster-item {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .book-consultation__cluster-image,
  .book-consultation__cluster-placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: top;
  }

  .book-consultation-{{ section.id }}__intro-group {
    max-width: 100%;
    margin: 0 auto;
    display: grid;
    gap: 0;
    padding-top: 0;
    padding-bottom: 128px;
  }

  .book-consultation-{{ section.id }} .about-founder__inner.page-width {
    padding-block: 128px;
  }

  .book-consultation-{{ section.id }}__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    min-height: 0;
    align-self: start;
    overflow: hidden;
  }

  .book-consultation-{{ section.id }}__image-wrap .book-consultation-{{ section.id }}__intro-video {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .book-consultation-{{ section.id }}__image-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    min-height: 0;
    background: rgba(var(--color-foreground), 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .book-consultation-{{ section.id }}__image-placeholder .placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .book-consultation-{{ section.id }}__intro {
    text-align: left;
    padding: 2rem 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media screen and (min-width: 768px) {
    .book-consultation-{{ section.id }}__intro {
      padding: 4rem;
    }
  }

  .book-consultation-{{ section.id }}__title {
    margin: 0 0 1.5rem;
    font-size: 4rem 0;
    line-height: 1.05;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .book-consultation-{{ section.id }}__price {
    margin: 0 0 2rem;
    display: inline-flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
  }

  .book-consultation-{{ section.id }}__body {
    max-width: 52rem;
    margin-bottom: 2.4rem;
    color: rgba(var(--color-foreground), 0.8);
    line-height: 1.7;
  }

  .book-consultation-{{ section.id }} .product-form__buttons {
    margin-top: 1.5rem;
    display: flex;
    justify-content: flex-start;
  }

  .book-consultation-{{ section.id }} .product-form__submit {
    min-height: 3.5rem;
    padding-inline: 2.8rem;
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .book-consultation-{{ section.id }}__calendar {
    margin-top: 2rem;
    border-radius: 0.5rem;
    background: rgba(var(--color-foreground), 0.03);
    padding: 1.75rem;
  }

  .book-consultation-{{ section.id }}__calendar-placeholder {
    margin: 0;
    font-size: 0.95rem;
    color: rgba(var(--color-foreground), 0.7);
  }

  .book-consultation-{{ section.id }}__video-gallery {
    margin: 0 auto;
    padding-top: 2rem;
  }

  .book-consultation-{{ section.id }}__video-gallery .collection__title {
    text-align: center;
    text-transform: uppercase;
  }

  .book-consultation-{{ section.id }}__video-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .book-consultation-{{ section.id }}__video-card {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border: 1px solid rgba(var(--color-foreground), 0.12);
    background: transparent;
    padding: 0;
    cursor: pointer;
  }

  .book-consultation-{{ section.id }}__video-card.is-active {
    border-color: rgba(var(--color-foreground), 0.45);
  }

  .book-consultation-{{ section.id }}__video-card video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .book-consultation-{{ section.id }}__video-placeholder {
    width: 100%;
    height: 100%;
    background: rgba(var(--color-foreground), 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .book-consultation-{{ section.id }}__intro-group {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.1fr);
      align-items: stretch;
    }

    .book-consultation-{{ section.id }}__video-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .book-consultation-{{ section.id }}__video-grid .book-consultation-{{ section.id }}__video-card:last-child {
      grid-column: 1 / -1;
    }
  }

  @media screen and (min-width: 1024px) {
    .book-consultation-{{ section.id }}__cluster {
      flex-direction: row;
      gap: 0;
      padding: 0;
    }

    .book-consultation-{{ section.id }}__cluster-item {
      flex: 1 1 50%;
    }

    .book-consultation-{{ section.id }}__video-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .book-consultation-{{ section.id }}__video-grid .book-consultation-{{ section.id }}__video-card:last-child {
      grid-column: auto;
    }
  }
{%- endstyle -%}

<section class="book-consultation-{{ section.id }} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="book-consultation-{{ section.id }}__intro-group">
      <div class="book-consultation-{{ section.id }}__image-wrap">
        {%- if section.settings.intro_video != blank -%}
          {%- assign intro_video_class = 'book-consultation-' | append: section.id | append: '__intro-video' -%}
          {{
            section.settings.intro_video
            | video_tag:
              class: intro_video_class,
              image_size: '900x',
              autoplay: true,
              loop: true,
              muted: true,
              controls: false,
              playsinline: true
          }}
        {%- else -%}
          <div class="book-consultation-{{ section.id }}__image-placeholder">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="book-consultation-{{ section.id }}__intro">
        <h2 class="book-consultation-{{ section.id }}__title">{{ product.title | escape }}</h2>

        <div class="book-consultation-{{ section.id }}__price">
          {% render 'price', product: product, use_variant: true, show_badges: false %}
        </div>

        {%- if product.description != blank -%}
          <div class="book-consultation-{{ section.id }}__body rte">
            {{ product.description }}
          </div>
        {%- endif -%}

        {%- assign product_form_id = 'book-consultation-form-' | append: section.id -%}
        <product-form class="product-form" data-section-id="{{ section.id }}">
          {%- form 'product',
            product,
            id: product_form_id,
            class: 'form',
            novalidate: 'novalidate',
            data-type: 'add-to-cart-form'
          -%}
            <input
              type="hidden"
              name="id"
              value="{{ product.selected_or_first_available_variant.id }}"
              {% if product.selected_or_first_available_variant == null
                or product.selected_or_first_available_variant.available == false
              %}
                disabled
              {% endif %}
            >
            <input type="hidden" name="quantity" value="1">

            <div class="product-form__buttons">
              <button
                type="submit"
                name="add"
                class="product-form__submit button button--secondary"
                {% if product.selected_or_first_available_variant == null
                  or product.selected_or_first_available_variant.available == false
                %}
                  disabled
                {% endif %}
              >
                <span>{{ section.settings.button_label | escape }}</span>
              </button>
            </div>
          {%- endform -%}
        </product-form>
      </div>
    </div>
  </div>

  <div class="book-consultation-{{ section.id }}__callout">
    <h2 class="book-consultation-{{ section.id }}__callout-heading">
      {{ callout_heading | escape }}
    </h2>
  </div>

  <div class="about-founder__inner page-width">
    <div class="book-consultation-{{ section.id }}__cluster">
      <div class="book-consultation-{{ section.id }}__cluster-item book-consultation-{{ section.id }}__cluster-item--a">
        {%- if section.settings.cluster_image_left != blank -%}
          {{
            section.settings.cluster_image_left
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              class: 'book-consultation__cluster-image',
              widths: '400, 550, 700, 900, 1200',
              sizes: '(min-width: 1024px) 50vw, 100vw'
          }}
        {%- else -%}
          <div class="book-consultation-{{ section.id }}__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg book-consultation__cluster-placeholder' }}
          </div>
        {%- endif -%}
      </div>
      <div class="book-consultation-{{ section.id }}__cluster-item book-consultation-{{ section.id }}__cluster-item--b">
        {%- if section.settings.cluster_image_right != blank -%}
          {{
            section.settings.cluster_image_right
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              class: 'book-consultation__cluster-image',
              widths: '400, 550, 700, 900, 1200',
              sizes: '(min-width: 1024px) 50vw, 100vw'
          }}
        {%- else -%}
          <div class="book-consultation-{{ section.id }}__placeholder">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg book-consultation__cluster-placeholder' }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="book-consultation-{{ section.id }}__video-gallery" data-consult-video-gallery>
    <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width">
      {%- if section.settings.video_gallery_title != blank -%}
        <h2 class="title inline-richtext {{ section.settings.video_gallery_heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.video_gallery_title }}
        </h2>
      {%- endif -%}
    </div>
    <div class="page-width">
      <div class="book-consultation-{{ section.id }}__video-grid">
        {%- for i in (1..3) -%}
          {%- capture video_setting_key -%}gallery_video_{{ i }}{%- endcapture -%}
          {%- assign card_video = section.settings[video_setting_key] -%}
          <button
            type="button"
            class="book-consultation-{{ section.id }}__video-card"
            data-video-card
            data-video-index="{{ forloop.index0 }}"
            aria-label="Play consultation video {{ i }}"
          >
            {%- if card_video != blank -%}
              {{
                card_video
                | video_tag:
                  image_size: '900x',
                  autoplay: false,
                  loop: false,
                  muted: true,
                  controls: false,
                  playsinline: true
              }}
            {%- else -%}
              <div class="book-consultation-{{ section.id }}__video-placeholder">
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </button>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const sectionId = 'shopify-section-{{ section.id }}';

    const initVideoGallery = (root) => {
      const gallery = root.querySelector('[data-consult-video-gallery]');
      if (!gallery || gallery.dataset.initialized === 'true') return;

      const cards = Array.from(gallery.querySelectorAll('[data-video-card]'));
      const videos = cards.map((card) => card.querySelector('video')).filter((videoEl) => videoEl);

      if (videos.length === 0) {
        gallery.dataset.initialized = 'true';
        return;
      }

      let currentIndex = 0;

      const setActive = (nextIndex) => {
        currentIndex = nextIndex;
        videos.forEach((videoEl, index) => {
          const card = videoEl.closest('[data-video-card]');
          if (index === currentIndex) {
            card.classList.add('is-active');
            videoEl.muted = true;
            videoEl.play().catch(() => {});
          } else {
            card.classList.remove('is-active');
            videoEl.pause();
          }
        });
      };

      videos.forEach((videoEl, index) => {
        videoEl.addEventListener('ended', () => {
          if (index !== currentIndex) return;
          videoEl.currentTime = 0;
          const nextIndex = (currentIndex + 1) % videos.length;
          setActive(nextIndex);
        });

        const card = videoEl.closest('[data-video-card]');
        if (card) {
          card.addEventListener('click', () => {
            setActive(index);
          });
        }
      });

      setActive(0);
      gallery.dataset.initialized = 'true';
    };

    const mount = () => {
      const sectionRoot = document.getElementById(sectionId);
      if (sectionRoot) initVideoGallery(sectionRoot);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mount, { once: true });
    } else {
      mount();
    }

    document.addEventListener('shopify:section:load', (event) => {
      if (event.target && event.target.id === sectionId) {
        initVideoGallery(event.target);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Book consultation product",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "video",
      "id": "intro_video",
      "label": "Left column video"
    },
    {
      "type": "inline_richtext",
      "id": "video_gallery_title",
      "label": "Video gallery title",
      "default": "FEMININITY CUSTOMIZED"
    },
    {
      "type": "select",
      "id": "video_gallery_heading_size",
      "label": "Video gallery heading size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        },
        {
          "value": "hxl",
          "label": "Extra large"
        },
        {
          "value": "hxxl",
          "label": "Extra extra large"
        }
      ],
      "default": "h2"
    },
    {
      "type": "video",
      "id": "gallery_video_1",
      "label": "Gallery video 1"
    },
    {
      "type": "video",
      "id": "gallery_video_2",
      "label": "Gallery video 2"
    },
    {
      "type": "video",
      "id": "gallery_video_3",
      "label": "Gallery video 3"
    },
    {
      "type": "text",
      "id": "callout_text",
      "label": "Callout text",
      "default": "Feel the Magic in Every Conversation"
    },
    {
      "type": "image_picker",
      "id": "cluster_image_left",
      "label": "Bottom left image"
    },
    {
      "type": "image_picker",
      "id": "cluster_image_right",
      "label": "Bottom right image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Fallback button label",
      "default": "Book now"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 128
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Book consultation product"
    }
  ]
}
{% endschema %}

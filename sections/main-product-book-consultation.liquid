{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .book-consultation-{{ section.id }} {
    background: rgb(var(--color-background));
  }

  .book-consultation-{{ section.id }} .page-width {
    /* max-width: 90rem; */
    margin-inline: auto;
  }

  .book-consultation-{{ section.id }}__placeholder,
  .book-consultation-{{ section.id }} .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .book-consultation-{{ section.id }}__placeholder {
    background: rgba(var(--color-foreground), 0.06);
  }

  .book-consultation-{{ section.id }}__callout {
    min-height: 12rem;
    background: {{ settings.color_accent_porcelain | default: '#F3EDE8' }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .book-consultation-{{ section.id }}__callout-heading {
    margin: 0;
    font-size: clamp(1.9rem, 4.3vw, 3.5rem);
    font-family: "Times New Roman", Georgia, serif;
    font-style: italic;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    line-height: 1.2;
  }

  .book-consultation-{{ section.id }}__cluster {
    display: flex;
    flex-direction: column;
  }

  .book-consultation-{{ section.id }}__cluster-item {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .book-consultation__cluster-image,
  .book-consultation__cluster-placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: top;
  }

  .book-consultation-{{ section.id }}__intro-group {
    max-width: 100%;
    margin: 0 auto;
    display: grid;
    gap: 0;
    padding-top: 0;
    padding-bottom: 128px;
  }

  .book-consultation-{{ section.id }} .about-founder__inner.page-width {
    padding-block: 128px;
  }

  .book-consultation-{{ section.id }}__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    min-height: 0;
    align-self: start;
    overflow: hidden;
  }

  .book-consultation-{{ section.id }}__image-wrap .book-consultation-{{ section.id }}__image-img {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .book-consultation-{{ section.id }}__image-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    min-height: 0;
    background: rgba(var(--color-foreground), 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .book-consultation-{{ section.id }}__image-placeholder .placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .book-consultation-{{ section.id }}__intro {
    text-align: left;
    padding: clamp(2.2rem, 6vw, 5.5rem) clamp(1.8rem, 5vw, 4rem);
    min-height: clamp(22rem, 54vw, 38rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .book-consultation-{{ section.id }}__title {
    margin: 0 0 1.5rem;
    font-size: 2rem;
    line-height: 1.05;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .book-consultation-{{ section.id }}__price {
    margin: 0 0 2rem;
    display: inline-flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
  }

  .book-consultation-{{ section.id }}__body {
    max-width: 52rem;
    margin-bottom: 2.4rem;
    color: rgba(var(--color-foreground), 0.8);
    line-height: 1.7;
  }

  .book-consultation-{{ section.id }} .product-form__buttons {
    margin-top: 1.5rem;
    display: flex;
    justify-content: flex-start;
  }

  .book-consultation-{{ section.id }} .product-form__submit {
    min-height: 3.5rem;
    padding-inline: 2.8rem;
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .book-consultation-{{ section.id }}__calendar {
    margin-top: 2rem;
    border-radius: 0.5rem;
    background: rgba(var(--color-foreground), 0.03);
    padding: 1.75rem;
  }

  .book-consultation-{{ section.id }}__calendar-placeholder {
    margin: 0;
    font-size: 0.95rem;
    color: rgba(var(--color-foreground), 0.7);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .book-consultation-{{ section.id }}__intro-group {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.1fr);
      align-items: stretch;
    }
  }

  @media screen and (min-width: 990px) {
    .book-consultation-{{ section.id }}__cluster {
      flex-direction: row;
      gap: 0;
    }

    .book-consultation-{{ section.id }}__cluster-item {
      flex: 1 1 50%;
    }
  }
{%- endstyle -%}

<section class="book-consultation-{{ section.id }} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="book-consultation-{{ section.id }}__intro-group">
      <div class="book-consultation-{{ section.id }}__image-wrap">
        {%- if section.settings.image != blank -%}
          {%- assign image_class = 'book-consultation-' | append: section.id | append: '__image-img' -%}
          {{
            section.settings.image
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              class: image_class,
              widths: '400, 550, 700, 900',
              sizes: '(min-width: 990px) 50vw, 100vw'
          }}
        {%- else -%}
          <div class="book-consultation-{{ section.id }}__image-placeholder">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="book-consultation-{{ section.id }}__intro">
        <h2 class="book-consultation-{{ section.id }}__title">{{ product.title | escape }}</h2>

        <div class="book-consultation-{{ section.id }}__price">
          {% render 'price', product: product, use_variant: true, show_badges: false %}
        </div>

        {%- if product.description != blank -%}
          <div class="book-consultation-{{ section.id }}__body rte">
            {{ product.description }}
          </div>
        {%- endif -%}

        {%- assign product_form_id = 'book-consultation-form-' | append: section.id -%}
        <product-form class="product-form" data-section-id="{{ section.id }}">
          {%- form 'product',
            product,
            id: product_form_id,
            class: 'form',
            novalidate: 'novalidate',
            data-type: 'add-to-cart-form'
          -%}
            <input
              type="hidden"
              name="id"
              value="{{ product.selected_or_first_available_variant.id }}"
              {% if product.selected_or_first_available_variant == null
                or product.selected_or_first_available_variant.available == false
              %}
                disabled
              {% endif %}
            >
            <input type="hidden" name="quantity" value="1">

            <div class="product-form__buttons">
              <button
                type="submit"
                name="add"
                class="product-form__submit button button--secondary"
                {% if product.selected_or_first_available_variant == null
                  or product.selected_or_first_available_variant.available == false
                %}
                  disabled
                {% endif %}
              >
                <span>{{ section.settings.button_label | escape }}</span>
              </button>
            </div>
          {%- endform -%}
        </product-form>
      </div>
    </div>
  </div>

  <div class="book-consultation-{{ section.id }}__callout">
    <h2 class="book-consultation-{{ section.id }}__callout-heading">
      {{ section.settings.callout_text | escape }}
    </h2>
  </div>

  <div class="about-founder__inner page-width">
    <div class="book-consultation-{{ section.id }}__cluster">
      <div class="book-consultation-{{ section.id }}__cluster-item book-consultation-{{ section.id }}__cluster-item--a">
        {%- if section.settings.cluster_image_left != blank -%}
          {{
            section.settings.cluster_image_left
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              class: 'book-consultation__cluster-image',
              widths: '400, 550, 700, 900, 1200',
              sizes: '(min-width: 990px) 50vw, 100vw'
          }}
        {%- else -%}
          <div class="book-consultation-{{ section.id }}__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg book-consultation__cluster-placeholder' }}
          </div>
        {%- endif -%}
      </div>
      <div class="book-consultation-{{ section.id }}__cluster-item book-consultation-{{ section.id }}__cluster-item--b">
        {%- if section.settings.cluster_image_right != blank -%}
          {{
            section.settings.cluster_image_right
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              class: 'book-consultation__cluster-image',
              widths: '400, 550, 700, 900, 1200',
              sizes: '(min-width: 990px) 50vw, 100vw'
          }}
        {%- else -%}
          <div class="book-consultation-{{ section.id }}__placeholder">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg book-consultation__cluster-placeholder' }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Book consultation product",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left column image"
    },
    {
      "type": "text",
      "id": "callout_text",
      "label": "Callout text",
      "default": "Feel the Magic in Every Conversation"
    },
    {
      "type": "image_picker",
      "id": "cluster_image_left",
      "label": "Bottom left image"
    },
    {
      "type": "image_picker",
      "id": "cluster_image_right",
      "label": "Bottom right image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Fallback button label",
      "default": "Book now"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 128
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Book consultation product"
    }
  ]
}
{% endschema %}

{%- style -%}
  .policy-content-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .policy-content-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign use_blocks = false
  if section.blocks.size > 0
    assign use_blocks = true
  endif
-%}

<section class="policy-content policy-content-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="policy-content__inner page-width">
    {%- if use_blocks -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="policy-content__heading">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}
      {%- for block in section.blocks -%}
        <div class="policy-content__block" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <h2 class="policy-content__subheading">{{ block.settings.title | escape }}</h2>
          {%- endif -%}
          {%- if block.settings.content != blank -%}
            <div class="policy-content__rte policy-content__rte--text">
              {%- assign paras = block.settings.content | split: '
' -%}
              {%- for p in paras -%}
                {%- assign trimmed = p | strip -%}
                {%- if trimmed != '' -%}
                  <p>{{ trimmed | escape }}</p>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Default policy fallback intentionally blank; manage policy copy through template blocks. {%- endcomment -%}
      {%- assign policy_heading = section.settings.heading | default: page.title | default: 'Policy' -%}
      {%- assign policy_body = '' -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="policy-content__heading">{{ section.settings.heading | escape }}</h1>
      {%- elsif policy_heading != blank -%}
        <h1 class="policy-content__heading">{{ policy_heading | escape }}</h1>
      {%- endif -%}

      {%- if policy_body != blank -%}
        <div class="policy-content__rte policy-content__rte--text">
          {%- assign segments = policy_body | split: '
' -%}
          {%- for line in segments -%}
            {%- assign trimmed = line | strip -%}
            {%- if trimmed == '' -%}
              {%- continue -%}
            {%- endif -%}
            {%- assign line_start = trimmed | slice: 0, 2 -%}
            {%- assign line_start_three = trimmed | slice: 0, 3 -%}
            {%- if line_start_three == '## ' -%}
              {%- assign heading_text = trimmed | remove_first: '## ' | strip -%}
              <h2 class="policy-content__subheading">{{ heading_text | escape }}</h2>
            {%- elsif line_start == '- ' -%}
              <p>{{ trimmed | remove_first: '- ' | strip | escape }}</p>
            {%- else -%}
              <p>{{ trimmed | escape }}</p>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

<style>
  /* Inner uses .page-width: inherit global max-width (1440px) + horizontal padding from base.css */
  .policy-content__heading {
    margin: 0 0 2rem;
    font-family: var(--font-heading-family);
    font-size: clamp(1.6rem, 4vw, 2.3rem);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    text-align: center;
  }
  .policy-content__block {
    margin-bottom: 2rem;
  }
  .policy-content__subheading {
    margin: 0 0 0.8rem;
    font-family: var(--font-heading-family);
    font-size: clamp(1rem, 2.2vw, 1.7rem);
    font-weight: 700;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
  }
  .policy-content__rte {
    color: rgba(var(--color-foreground), 0.9);
    line-height: 1.8;
  }
  .policy-content__rte p,
  .policy-content__rte .policy-content__list {
    margin: 0 0 0.8rem;
  }
  .policy-content__rte .policy-content__list {
    padding-left: 1.5rem;
  }
  .policy-content__rte li {
    margin-bottom: 0.25rem;
  }
</style>

{% schema %}
{
  "name": "Policy content",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "policy_type",
      "label": "Policy page (when using default content)",
      "default": "returns_and_exchanges",
      "options": [
        { "value": "returns_and_exchanges", "label": "Returns and exchanges" },
        { "value": "privacy_policy", "label": "Privacy policy" },
        { "value": "payment_policy", "label": "Payment policy" },
        { "value": "delivery_policy", "label": "Delivery policy" }
      ],
      "info": "Used when no content blocks are added. Add blocks in the theme editor to override with custom content (plain text)."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 128
    }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "Content block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Section title"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content (plain text; one paragraph per line)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Policy content",
      "settings": {
        "policy_type": "returns_and_exchanges"
      }
    }
  ]
}
{% endschema %}

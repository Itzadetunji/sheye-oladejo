{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
<section
  class="collection-1-boca collection-1-boca--{{ section.id }}"
  aria-labelledby="collection-1-boca-title-{{ section.id }}"
>
  <div class="collection-1-boca__hero tile tile--hero">
    <div class="collection-1-boca__hero-media">
      {%- if section.settings.hero_image != blank -%}
        {{
          section.settings.hero_image
          | image_url: width: 1920
          | image_tag:
            loading: 'eager',
            class: 'collection-1-boca__hero-image',
            sizes: '100vw',
            widths: '750, 1100, 1500, 1920'
        }}
      {%- else -%}
        <div class="collection-1-boca__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>
    <div class="collection-1-boca__hero-heading">
      <h1 id="collection-1-boca-title-{{ section.id }}" class="collection-1-boca__hero-title">
        {{ section.settings.hero_title | escape }}
      </h1>
      <svg
        preserveAspectRatio="xMidYMid meet"
        data-bbox="2 2 20 20"
        stroke-width="1.2"
        stroke="#ffffff"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        height="28"
        width="28"
        data-type="ugc"
        role="presentation"
        aria-hidden="true"
        aria-label=""
        class="collection-1-boca__magic-icon"
      >
        <g>
          <path
            stroke-linejoin="round"
            stroke-linecap="round"
            d="m6.5 13 .784 1.569c.266.53.399.796.576 1.026a3 3 0 0 0 .545.545c.23.177.495.31 1.026.575L11 17.5l-1.569.785c-.53.265-.796.398-1.026.575a3 3 0 0 0-.545.545c-.177.23-.31.495-.576 1.026L6.5 22l-.784-1.569c-.266-.53-.399-.796-.576-1.026a3 3 0 0 0-.545-.545c-.23-.177-.495-.31-1.026-.575L2 17.5l1.569-.785c.53-.265.796-.398 1.026-.575a3 3 0 0 0 .545-.545c.177-.23.31-.495.576-1.026L6.5 13Z"
            fill="none"
          ></path>
          <path
            stroke-linejoin="round"
            stroke-linecap="round"
            d="m15 2 1.179 3.064c.282.734.423 1.1.642 1.409a3 3 0 0 0 .706.706c.309.22.675.36 1.409.642L22 9l-3.064 1.179c-.734.282-1.1.423-1.409.642a3 3 0 0 0-.706.706c-.22.309-.36.675-.642 1.409L15 16l-1.179-3.064c-.282-.734-.423-1.1-.642-1.409a3 3 0 0 0-.706-.706c-.309-.22-.675-.36-1.409-.642L8 9l3.064-1.179c.734-.282 1.1-.423 1.409-.642a3 3 0 0 0 .706-.706c.22-.309.36-.675.642-1.409L15 2Z"
            fill="none"
          ></path>
        </g>
      </svg>
    </div>
  </div>

  <div class="collection-1-boca__intro-group">
    <div class="collection-1-boca__intro tile tile--text">
      <div class="collection-1-boca__intro-inner">
        <div class="collection-1-boca__intro-heading">
          <h2 class="collection-1-boca__script">{{ section.settings.intro_heading | escape }}</h2>
          <svg
            preserveAspectRatio="xMidYMid meet"
            data-bbox="2 2 20 20"
            stroke-width="1.2"
            stroke="#000000"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            height="28"
            width="28"
            data-type="ugc"
            role="presentation"
            aria-hidden="true"
            aria-label=""
            class="collection-1-boca__magic-icon collection-1-boca__magic-icon--intro"
          >
            <g>
              <path
                stroke-linejoin="round"
                stroke-linecap="round"
                d="m6.5 13 .784 1.569c.266.53.399.796.576 1.026a3 3 0 0 0 .545.545c.23.177.495.31 1.026.575L11 17.5l-1.569.785c-.53.265-.796.398-1.026.575a3 3 0 0 0-.545.545c-.177.23-.31.495-.576 1.026L6.5 22l-.784-1.569c-.266-.53-.399-.796-.576-1.026a3 3 0 0 0-.545-.545c-.23-.177-.495-.31-1.026-.575L2 17.5l1.569-.785c.53-.265.796-.398 1.026-.575a3 3 0 0 0 .545-.545c.177-.23.31-.495.576-1.026L6.5 13Z"
                fill="none"
              ></path>
              <path
                stroke-linejoin="round"
                stroke-linecap="round"
                d="m15 2 1.179 3.064c.282.734.423 1.1.642 1.409a3 3 0 0 0 .706.706c.309.22.675.36 1.409.642L22 9l-3.064 1.179c-.734.282-1.1.423-1.409.642a3 3 0 0 0-.706.706c-.22.309-.36.675-.642 1.409L15 16l-1.179-3.064c-.282-.734-.423-1.1-.642-1.409a3 3 0 0 0-.706-.706c-.309-.22-.675-.36-1.409-.642L8 9l3.064-1.179c.734-.282 1.1-.423 1.409-.642a3 3 0 0 0 .706-.706c.22-.309.36-.675.642-1.409L15 2Z"
                fill="none"
              ></path>
            </g>
          </svg>
        </div>
        <div class="collection-1-boca__intro-copy">
          <p>{{ section.settings.intro_body_1 | escape }}</p>
          <p>{{ section.settings.intro_body_2 | escape }}</p>
        </div>
      </div>
    </div>

    <div class="collection-1-boca__image tile tile--intro-image">
      <div class="collection-1-boca__placeholder">
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    </div>
  </div>
  <div class="collection-1-boca__bottom-group">
    <div class="collection-1-boca__bottom tile tile--bottom-left">
      <div class="collection-1-boca__placeholder">
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    </div>

    <div class="collection-1-boca__bottom tile tile--bottom-center">
      <div class="collection-1-boca__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    </div>

    <div class="collection-1-boca__bottom tile tile--bottom-right">
      <div class="collection-1-boca__placeholder">
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    </div>
  </div>

  <div class="collection-1-boca__callout tile tile--callout">
    <h2>{{ section.settings.callout_text | escape }}</h2>
  </div>

  {%- assign boca_collection = collections['boca-magic-products'] -%}
  {%- if boca_collection != blank and boca_collection.products.size > 0 -%}
    <div class="collection-1-boca__products">
      <div class="collection-1-boca__products-inner page-width collection">
        <ul
          id="Collection1ProductGrid-{{ section.id }}"
          class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} product-grid--alternating-3-2"
          role="list"
        >
          {%- assign skip_card_product_styles = false -%}
          {%- for product in boca_collection.products limit: 3 -%}
            {% assign lazy_load = false %}
            {% if forloop.index > 2 %}
              {% assign lazy_load = true %}
            {% endif %}
            {% assign cycle_index = forloop.index0 | modulo: 5 %}
            {% if cycle_index == 3 or cycle_index == 4 %}
              {% assign span_class = 'grid__item--span-3' %}
            {% else %}
              {% assign span_class = 'grid__item--span-2' %}
            {% endif %}
            <li class="grid__item {{ span_class }}">
              {% render 'card-product',
                card_product: product,
                media_aspect_ratio: 'adapt',
                image_shape: 'default',
                lazy_load: lazy_load,
                show_secondary_image: false,
                show_vendor: false,
                show_rating: false,
                skip_styles: skip_card_product_styles,
                section_id: section.id,
                quick_add: 'none',
                skip_skeleton: true
              %}
            </li>
            {%- assign skip_card_product_styles = true -%}
          {%- endfor -%}
        </ul>
        <div class="collection-1-boca__products-cta">
          <a href="/collections/boca-magic-products" class="button button--primary">
            {{ section.settings.products_button_text | default: 'View all Boca Magic' | escape }}
          </a>
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="collection-1-boca__cluster">
    <div class="collection-1-boca__image tile tile--a">
      <div class="collection-1-boca__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    </div>

    <div class="collection-1-boca__image tile tile--b">
      <div class="collection-1-boca__placeholder">
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    </div>

    <div class="collection-1-boca__image tile tile--c">
      <div class="collection-1-boca__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    </div>
  </div>
</section>

{%- style -%}
  .collection-1-boca--{{ section.id }} {
    --boca-bg: {{ section.settings.canvas_color }};
    --boca-text: {{ section.settings.text_color }};
    --boca-muted: {{ section.settings.muted_text_color }};
    color: var(--boca-text);
  }

  .collection-1-boca--{{ section.id }} .tile {
    position: relative;
    min-height: 22rem;
    overflow: hidden;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__hero-media {
    position: absolute;
    inset: 0;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__placeholder,
  .collection-1-boca--{{ section.id }} .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__placeholder {
    background: rgba(255, 255, 255, 0.12);
  }

  .collection-1-boca--{{ section.id }} .placeholder-svg {
    object-fit: cover;
    opacity: 0.45;
  }

  .collection-1-boca--{{ section.id }} .tile--hero {
    min-height: clamp(26rem, 62vw, 44rem);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .collection-1-boca--{{ section.id }} .tile--hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.35));
    pointer-events: none;
  }

  .collection-1-boca__hero-heading{
    z-index: 1;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__hero-heading {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__hero-title {
    margin: 0;
    color: #fff;
    font-family: "Times New Roman", Georgia, serif;
    font-style: italic;
    font-weight: 500;
    letter-spacing: 0.02em;
    font-size: 2.75rem;
    text-align: center;

  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__magic-icon {
    width: 28px;
    height: 28px;
    animation: flicker 1.4s ease-in-out infinite;
    animation-delay: 2s;
    position:absolute;
    top: 0;
    left: 100%;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__hero-heading .collection-1-boca__magic-icon {
    stroke: #ffffff;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__magic-icon--intro {
    stroke: #000000;
  }

  .collection-1-boca--{{ section.id }} .tile--text {
    background: {{ settings.color_accent_porcelain | default: '#F3EDE8' }};
    color: var(--boca-text);
    padding: clamp(2.2rem, 6vw, 5.5rem) clamp(1.8rem, 5vw, 4rem);
    min-height: clamp(22rem, 54vw, 38rem);
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__intro {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    text-align: left;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__intro-inner {
    width: 100%;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__intro-heading {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    position: relative;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__intro-copy {
    display: flex;
    flex-direction: column;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__script {
    margin: 0 0 1.8rem;
    font-family: "Times New Roman", Georgia, serif;
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2.4rem, 4.5vw, 4.3rem);
    line-height: 1.1;
  }

  .collection-1-boca--{{ section.id }} .tile--text p {
    margin: 0 0 1.2rem;
    max-width: 60ch;
    font-size: 0.75rem;
    line-height: 1.65;
    color: var(--boca-muted);
  }

  .collection-1-boca--{{ section.id }} .tile--callout {
    min-height: 12rem;
    background: {{ settings.color_accent_porcelain | default: '#F3EDE8' }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .collection-1-boca--{{ section.id }} .tile--callout h2 {
    margin: 0;
    font-size: clamp(1.9rem, 4.3vw, 3.5rem);
    font-family: "Times New Roman", Georgia, serif;
    font-style: italic;
    font-weight: 500;
    color: var(--boca-text);
    line-height: 1.2;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__bottom-group {
    display: grid;
    grid-template-columns: 1fr;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__bottom {
    position: relative;
    height: 640px;
    min-height: 640px;
    overflow: hidden;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__bottom .collection-1-boca__placeholder {
    position: absolute;
    inset: 0;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__products {
    padding: clamp(2rem, 5vw, 4rem) 0;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__products-inner {
    margin: 0 auto;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__products .product-grid {
    margin-bottom: 2rem;
    justify-content: flex-start;
  }

  @media screen and (min-width: 750px) {
    .collection-1-boca--{{ section.id }} .collection-1-boca__products .product-grid {
      justify-content: center;
    }
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__products .card__heading,
  .collection-1-boca--{{ section.id }} .collection-1-boca__products .card__heading a {
    text-transform: uppercase;
    text-align: left;
  }

  @media screen and (min-width: 750px) {
    .collection-1-boca--{{ section.id }} .collection-1-boca__products .card__heading,
    .collection-1-boca--{{ section.id }} .collection-1-boca__products .card__heading a {
      text-align: center;
    }
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__products .product-grid .ratio {
    --ratio-percent: 133.333% !important;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__products-cta {
    text-align: center;
  }

  .collection-1-boca--{{ section.id }} .collection-1-boca__products-cta .button {
    min-width: 12rem;
  }

  @media screen and (min-width: 750px) {
    .collection-1-boca--{{ section.id }} .collection-1-boca__intro-group {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.1fr);
    }

    .collection-1-boca--{{ section.id }} .collection-1-boca__cluster {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: repeat(2, 1fr);
      height: 720px;
      min-height: 720px;
      gap: 0;
    }

    .collection-1-boca--{{ section.id }} .collection-1-boca__cluster .collection-1-boca__image {
      position: relative;
      height: 100%;
      overflow: hidden;
    }

    .collection-1-boca--{{ section.id }} .collection-1-boca__cluster .collection-1-boca__placeholder {
      position: absolute;
      inset: 0;
    }

    .collection-1-boca--{{ section.id }} .tile--a {
      grid-column: 2 / 3;
      grid-row: 1 / 2;
    }

    .collection-1-boca--{{ section.id }} .tile--b {
      grid-column: 2 / 3;
      grid-row: 2 / 3;
    }

    .collection-1-boca--{{ section.id }} .tile--c {
      grid-column: 1 / 2;
      grid-row: 1 / 3;
    }

    .collection-1-boca--{{ section.id }} .collection-1-boca__bottom-group {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @keyframes flicker {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    40% {
      opacity: 0.6;
      transform: scale(0.96);
    }
    60% {
      opacity: 1;
      transform: scale(1.04);
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Collection 1 Boca Magic",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "Boca Magic"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "intro_heading",
      "label": "Intro heading",
      "default": "Boca Magic"
    },
    {
      "type": "textarea",
      "id": "intro_body_1",
      "label": "Intro body line 1",
      "default": "The Boca Magic Collection comes alive with music, laughter, and pulsating dance steps, inspired by the vibrant neighborhood of La Boca in Buenos Aires. This collection reflects the bright colors and exciting music of this romantic Tango setting."
    },
    {
      "type": "textarea",
      "id": "intro_body_2",
      "label": "Intro body line 2",
      "default": "Designed to inspire fresh confidence in women, the Boca Magic Collection evokes curiosity, wonder, and spontaneous delight, capturing the spirit of adventure."
    },
    {
      "type": "text",
      "id": "callout_text",
      "label": "Callout text",
      "default": "Feel the Magic in Every Piece with Boca"
    },
    {
      "type": "text",
      "id": "products_button_text",
      "label": "Products section button text",
      "default": "View all Boca Magic"
    },
    {
      "type": "color",
      "id": "canvas_color",
      "label": "Canvas color",
      "default": "#b7ac9f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1e1e1e"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Body text color",
      "default": "#4a4a4a"
    }
  ],
  "presets": [
    {
      "name": "Collection 1 Boca Magic"
    }
  ]
}
{% endschema %}

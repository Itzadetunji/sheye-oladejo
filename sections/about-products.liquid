{{ 'component-video-gallery.css' | asset_url | stylesheet_tag }}
<script src="{{ 'video-gallery-component.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .about-products-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .about-products-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- assign blocks = section.blocks -%}
{%- assign padding_color = settings.color_accent_grey | default: '#D5D0CD' -%}

<section
  class="about-products about-products-{{ section.id }} color-{{ section.settings.color_scheme }} gradient"
  aria-labelledby="about-products-heading-{{ section.id }}"
>
  <div class="about-products__inner page-width">
    <h2 id="about-products-heading-{{ section.id }}" class="about-products__title visually-hidden">Our products</h2>
    <div class="about-products__masonry">
      {%- comment -%} Col 1: 25%, 50%, 24% — blocks 0, 3, 6 {%- endcomment -%}
      <div class="about-products__col">
        {%- for i in (0..2) -%}
          {%- assign idx = 0 -%}
          {%- if i == 0 -%}
            {%- assign idx = 0 -%}
          {%- elsif i == 1 -%}
            {%- assign idx = 3 -%}
          {%- else -%}
            {%- assign idx = 6 -%}
          {%- endif -%}
          {%- assign block = blocks[idx] -%}
          {%- if block.type == 'image' -%}
            <div class="about-products__cell about-products__cell--img" {{ block.shopify_attributes }}>
              {%- if i == 0 -%}
                {%- render 'about-products-image', block: block, image_class: 'about-products__cell_1_img' -%}
              {%- else -%}
                {%- render 'about-products-image', block: block -%}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Col 2: 40% (video), 30% (img), 30% (img pad) — blocks 1, 4, 7 {%- endcomment -%}
      <div class="about-products__col">
        {%- assign video_block = blocks[1] -%}
        {%- if video_block.type == 'video' -%}
          <div class="about-products__cell about-products__cell--video">
            {%- if video_block.settings.video != blank -%}
              <div class="video-gallery-component" data-video-gallery-component>
                {% render 'video-card',
                  card_video: video_block.settings.video,
                  card_label: video_block.settings.label,
                  card_index: 0,
                  card_fill: true,
                  block_attributes: video_block.shopify_attributes
                %}
              </div>
            {%- else -%}
              <div class="about-products__video-placeholder">
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- assign block4 = blocks[4] -%}
        {%- if block4.type == 'image' -%}
          <div class="about-products__cell about-products__cell--img" {{ block4.shopify_attributes }}>
            {%- render 'about-products-image', block: block4 -%}
          </div>
        {%- endif -%}
        {%- assign block7 = blocks[7] -%}
        {%- if block7.type == 'image' -%}
          <div
            class="about-products__cell about-products__cell--img about-products__cell--padded"
            {{ block7.shopify_attributes }}
          >
            <div class="about-products__cell-pad" style="background-color: {{ padding_color }};">
              {%- render 'about-products-image', block: block7 -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Col 3: 30%, 38% — blocks 5, 8 (items 6, 9) {%- endcomment -%}
      <div class="about-products__col">
        {%- assign col3_indices = '5,8' | split: ',' -%}
        {%- for i in (0..1) -%}
          {%- assign idx = col3_indices[i] | plus: 0 -%}
          {%- if idx < blocks.size -%}
            {%- assign block = blocks[idx] -%}
            {%- if block.type == 'image' -%}
              <div
                class="about-products__cell about-products__cell--img{% if i == 0 %} about-products__cell--padded{% endif %}"
                {{ block.shopify_attributes }}
              >
                {%- if i == 0 -%}
                  <div class="about-products__cell-pad" style="background-color: {{ padding_color }};">
                    {%- render 'about-products-image', block: block -%}
                  </div>
                {%- else -%}
                  {%- render 'about-products-image', block: block -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  .about-products {
    background-color: rgb(var(--color-background));
  }
  .about-products__inner {
    margin: 0 auto;
  }

  .about-products__masonry {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: start;
  }
  .about-products__col {
    display: grid;
    gap: 1rem;
  }

  @media screen and (min-width: 1024px) {
    .about-products__masonry {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      height: 1529px;
    }
    .about-products__col {
      display: grid;
      gap: 1rem;
      min-height: 0;
      height: 100%;
    }
    .about-products__col:nth-child(1) {
      grid-template-rows: 25fr 50fr 24fr;
    }
    .about-products__col:nth-child(2) {
      grid-template-rows: 40fr 30fr 30fr;
    }
    .about-products__col:nth-child(3) {
      grid-template-rows: 30fr 38fr;
    }
  }

  .about-products__cell {
    position: relative;
    overflow: hidden;
    min-height: 0;
  }
  .about-products__cell--img {
    width: 100%;
    height: 100%;
    background: transparent;
  }
  .about-products__cell--padded .about-products__cell-pad {
    width: 100%;
    height: 100%;
    padding: 1rem;
    box-sizing: border-box;
    overflow: hidden;
  }
  @media screen and (max-width: 1023px) {
    .about-products__cell--img {
      aspect-ratio: 3 / 4;
      height: auto;
    }
    .about-products__cell--padded .about-products__cell-pad {
      aspect-ratio: 3 / 4;
      height: auto;
    }
  }
  .about-products__cell--padded .about-products__cell-pad img,
  .about-products__cell--img .about-products__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .about-products__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    object-position: center top;
  }

  .about-products__cell_1_img {
    object-position: center 30%;
  }

  .about-products__cell--video {
    display: block;
  }
  .about-products__cell--video .video-gallery-component {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .about-products__cell--video .video-gallery-component__card,
  .about-products__cell--video video,
  .about-products__cell--video .about-products__video-placeholder {
    width: 100%;
    height: 100%;
    min-height: 20rem;
    display: block;
  }
  .about-products__cell--video video {
    object-fit: cover;
    object-position: center center;
  }
  @media screen and (max-width: 1023px) {
    .about-products__cell--video {
      width: 100%;
      aspect-ratio: 3 / 4;
    }
  }
</style>

{% schema %}
{
  "name": "Our products",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional – uses placeholder if blank)"
        }
      ]
    },
    {
      "type": "video",
      "name": "Video block",
      "limit": 1,
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted video"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Aria label",
          "default": "Play gallery video 1"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our products",
      "blocks": [
        { "type": "image" },
        { "type": "video" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}

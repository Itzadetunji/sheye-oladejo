{{ 'row-content-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .collection-about-row-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .collection-about-row-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="about-founder collection-about-row-{{ section.id }} color-{{ section.settings.color_scheme }} gradient"
  aria-labelledby="row-content-card-heading-{{ section.id }}"
>
  {% render 'row-content-card',
    image: section.settings.image,
    heading: section.settings.heading,
    body: section.settings.body,
    link: section.settings.link,
    reverse_layout: section.settings.reverse_layout,
    unique_id: section.id
  %}
</section>

{% schema %}
{
  "name": "Content card row",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Title",
      "default": "A STORY OF SOLIDARITY"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional — entire row is clickable when set)"
    },
    {
      "type": "checkbox",
      "id": "reverse_layout",
      "label": "Reverse image and text on desktop",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Content card row"
    }
  ]
}
{% endschema %}

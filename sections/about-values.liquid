{%- style -%}
  section.about-values.about-values-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px !important;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px !important;
  }
  @media screen and (min-width: 768px) {
    section.about-values.about-values-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom }}px !important;
    }
  }
{%- endstyle -%}

<section
  class="about-values about-values-{{ section.id }} color-{{ section.settings.color_scheme }} gradient"
  aria-labelledby="about-values-heading-{{ section.id }}"
>
  <div class="about-values__inner page-width">
    <h2 id="about-values-heading-{{ section.id }}" class="about-values__heading">
      {{ section.settings.heading | default: 'OUR CORE VALUES' | escape }}
    </h2>
    <div class="about-values__grid">
      {%- for block in section.blocks -%}
        <div class="about-values__column" {{ block.shopify_attributes }}>
          <h3 class="about-values__title">{{ block.settings.title | escape }}</h3>
          <div class="about-values__text">
            {%- assign lines = block.settings.text | split: '
' -%}
            {%- for line in lines -%}
              {%- assign trimmed = line | strip -%}
              {%- if trimmed != '' -%}
                <p>{{ trimmed | escape }}</p>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .about-values {
    background-color: rgb(var(--color-background));
  }
  .about-values__inner {
    margin: 0 auto;
    padding-left: 1rem;
    padding-right: 1rem;
  }
  @media screen and (min-width: 768px) {
    .about-values__inner {
      padding-left: 2.5rem;
      padding-right: 2.5rem;
    }
  }
  .about-values__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.4rem, 5vw, 2.2rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    text-align: center;
    margin: 0 0 2.5rem;
    line-height: 1.2;
  }
  .about-values__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media screen and (min-width: 768px) {
    .about-values__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem 3rem;
    }
  }
  .about-values__column {
    text-align: left;
  }
  .about-values__title {
    font-family: var(--font-heading-family);
    font-size: clamp(0.85rem, 2vw, 1.1rem);
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin: 0 0 1rem;
    line-height: 1.3;
  }
  .about-values__text {
    font-family: var(--font-body-family);
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.85);
  }
  .about-values__text p {
    margin: 0 0 0.75em;
  }
  .about-values__text p:last-child {
    margin-bottom: 0;
  }
</style>

{% schema %}
{
  "name": "Our core values",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR CORE VALUES"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 128
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 128
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our core values",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "title": "Exquisite Craftsmanship",
            "text": "Every garment at SheyeOladejo is a testament to our commitment to quality and artistry. We source the finest fabrics and embellishments from around the world, ensuring that each piece is a work of art. Our team of experienced designers and craftsmen utilize traditional couture techniques alongside innovative methods to create garments that are both timeless and contemporary."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Personalized Experience",
            "text": "We pride ourselves on offering a personalized and intimate experience for our clients. From the initial design consultation to the final fitting, we are dedicated to ensuring that your journey with us is exceptional. Our commitment to personalized service means that every client receives individual attention, creating an experience that is as memorable as the garment itself."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Sustainability and Ethics",
            "text": "At SheyeOladejo, we are committed to sustainable and ethical fashion practices. We strive to minimize our environmental footprint by using eco-friendly materials and sustainable production methods. Our dedication to ethical practices ensures that every garment is created with respect for both people and the planet."
          }
        }
      ]
    }
  ]
}
{% endschema %}

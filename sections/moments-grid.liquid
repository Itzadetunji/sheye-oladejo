{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-moment-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .product-grid {
    justify-content: flex-start;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .product-grid {
      justify-content: center;
    }
  }

  #shopify-section-{{ section.id }} .card__heading,
  #shopify-section-{{ section.id }} .card__heading a {
    text-transform: uppercase;
    text-align: left;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .card__heading,
    #shopify-section-{{ section.id }} .card__heading a {
      text-align: center;
    }
  }

  #shopify-section-{{ section.id }} .product-grid .ratio {
    --ratio-percent: 133.333% !important;
  }

  #shopify-section-{{ section.id }} .moments-grid__header {
    margin-bottom: 2rem;
  }

  #shopify-section-{{ section.id }} .moments-grid__header.center {
    text-align: center;
  }

  #shopify-section-{{ section.id }} .moments-grid__title {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .moments-grid__subheading {
    margin: 0;
    max-width: 42rem;
    margin-inline: auto;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.8);
  }

  #shopify-section-{{ section.id }} .moments-grid__header:not(.center) .moments-grid__subheading {
    margin-inline: 0;
  }

  #shopify-section-{{ section.id }} .moments-grid__empty {
    padding: 3rem 1rem;
    color: rgba(var(--color-foreground), 0.75);
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <header class="moments-grid__header{% if section.settings.heading_alignment == 'center' %} center{% endif %}">
        <h1 class="moments-grid__title">{{ section.settings.heading | escape }}</h1>
        {%- if section.settings.subheading != blank -%}
          <p class="moments-grid__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- liquid
      assign moments_collection = collections['moments']
      assign unique_tags = moments_collection.all_tags
    -%}

    {%- if unique_tags.size == 0 -%}
      <div class="moments-grid__empty center">
        <p>{{ 'sections.moments_grid.select_collection' | t }}</p>
      </div>
    {%- else -%}
      <div
        class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        <div class="collection">
          <ul
            id="product-grid"
            data-id="{{ section.id }}"
            class="
              grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} product-grid--alternating-3-2
              {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}
            "
            role="list"
          >
            {%- for tag in unique_tags limit: section.settings.max_tags -%}
              {%- assign lazy_load = false -%}
              {%- if forloop.index > 2 -%}
                {%- assign lazy_load = true -%}
              {%- endif -%}
              {%- assign cycle_index = forloop.index0 | modulo: 5 -%}
              {%- if cycle_index == 3 or cycle_index == 4 -%}
                {%- assign span_class = 'grid__item--span-3' -%}
              {%- else -%}
                {%- assign span_class = 'grid__item--span-2' -%}
              {%- endif -%}
              <li
                class="grid__item {{ span_class }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {% render 'moment-tag-card',
                  tag: tag,
                  link_collection: moments_collection,
                  section_id: section.id,
                  tag_index: forloop.index,
                  lazy_load: lazy_load,
                  skip_styles: true
                %}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Moments grid",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Moments"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_tags",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 24,
      "label": "Maximum tag cards",
      "info": "Limits how many tag cards are shown."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Moments grid"
    }
  ]
}
{% endschema %}

{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .product-grid .ratio {
    --ratio-percent: 133.333% !important;
  }

  #shopify-section-{{ section.id }} .moments-grid__header {
    margin-bottom: 2rem;
  }

  #shopify-section-{{ section.id }} .moments-grid__header.center {
    text-align: center;
  }

  #shopify-section-{{ section.id }} .moments-grid__title {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading-family);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .moments-grid__subheading {
    margin: 0;
    max-width: 42rem;
    margin-inline: auto;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.8);
  }

  #shopify-section-{{ section.id }} .moments-grid__header:not(.center) .moments-grid__subheading {
    margin-inline: 0;
  }

  #shopify-section-{{ section.id }} .moments-grid__empty {
    padding: 3rem 1rem;
    color: rgba(var(--color-foreground), 0.75);
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <header class="moments-grid__header{% if section.settings.heading_alignment == 'center' %} center{% endif %}">
        <h1 class="moments-grid__title">{{ section.settings.heading | escape }}</h1>
        {%- if section.settings.subheading != blank -%}
          <p class="moments-grid__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- assign moments_collection = section.settings.collection -%}
    {%- if moments_collection == blank -%}
      <div class="moments-grid__empty center">
        <p>{{ 'sections.moments_grid.select_collection' | t }}</p>
      </div>
    {%- else -%}
      {%- paginate moments_collection.products by section.settings.products_per_page -%}
        {%- if moments_collection.products.size == 0 -%}
          <div class="moments-grid__empty center">
            <p>{{ 'sections.collection_template.empty' | t }}</p>
          </div>
        {%- else -%}
          <ul
            class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} product-grid--alternating-3-2"
            role="list"
          >
            {%- assign skip_moment_styles = false -%}
            {%- for product in moments_collection.products -%}
              {%- assign lazy_load = false -%}
              {%- if forloop.index > 2 -%}
                {%- assign lazy_load = true -%}
              {%- endif -%}
              {%- assign cycle_index = forloop.index0 | modulo: 5 -%}
              {%- if cycle_index == 3 or cycle_index == 4 -%}
                {%- assign span_class = 'grid__item--span-3' -%}
              {%- else -%}
                {%- assign span_class = 'grid__item--span-2' -%}
              {%- endif -%}
              <li class="grid__item {{ span_class }}">
                {% render 'moment-card',
                  product: product,
                  section_id: section.id,
                  lazy_load: lazy_load,
                  skip_styles: skip_moment_styles
                %}
              </li>
              {%- assign skip_moment_styles = true -%}
            {%- endfor -%}
          </ul>

          {%- if paginate.pages > 1 -%}
            {% render 'pagination', paginate: paginate, anchor: '' %}
          {%- endif -%}
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Moments grid",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Moments collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Moments"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24,
      "label": "Products per page"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Moments grid"
    }
  ]
}
{% endschema %}

{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  ul {
    margin-block-start: 0
  }
    .collection-ejire-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 768px) {
      .collection-ejire-{{ section.id }} {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
{%- endstyle -%}

{%- liquid
  assign desktop_columns = section.settings.desktop_columns | default: 3 | plus: 0
  assign featured_collection = section.settings.collection
  assign featured_collection_handle = section.settings.collection.handle | default: section.settings.collection
  if featured_collection != blank and featured_collection.products == blank and featured_collection_handle != blank
    assign featured_collection = collections[featured_collection_handle]
  endif
  if featured_collection == blank and featured_collection_handle != blank
    assign featured_collection = collections[featured_collection_handle]
  endif
  if featured_collection == blank
    assign featured_collection = collections.ejire
  endif
  assign products_to_show = section.settings.products_to_show | default: 5 | plus: 0
  if products_to_show < 1
    assign products_to_show = 1
  endif
  if products_to_show > 12
    assign products_to_show = 12
  endif
  if desktop_columns < 2
    assign desktop_columns = 2
  endif
  if desktop_columns > 3
    assign desktop_columns = 3
  endif
  assign has_selected_products = false
  assign desktop_grid_class = 'grid--3-col-desktop'
  if desktop_columns == 2
    assign desktop_grid_class = 'grid--2-col-desktop'
  endif
-%}

<section class="collection-ejire collection-ejire-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <ul
      class="collection-ejire__grid grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--1-col-tablet-down {{ desktop_grid_class }}"
      role="list"
    >
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' and block.settings.product != blank -%}
          {%- assign has_selected_products = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if has_selected_products -%}
        {%- assign skip_card_product_styles = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' and block.settings.product != blank -%}
            {%- assign lazy_load = false -%}
            {%- if forloop.index > 2 -%}
              {%- assign lazy_load = true -%}
            {%- endif -%}
            <li class="collection-ejire__item grid__item" {{ block.shopify_attributes }}>
              {% render 'card-product',
                card_product: block.settings.product,
                media_aspect_ratio: 'adapt',
                image_shape: 'default',
                lazy_load: lazy_load,
                show_secondary_image: true,
                show_vendor: false,
                show_rating: false,
                skip_styles: skip_card_product_styles,
                section_id: section.id,
                quick_add: 'none',
                skip_skeleton: true
              %}
            </li>
            {%- assign skip_card_product_styles = true -%}
          {%- endif -%}
        {%- endfor -%}
      {%- elsif featured_collection != blank and featured_collection.products.size > 0 -%}
        {%- assign skip_card_product_styles = false -%}
        {%- for product in featured_collection.products limit: products_to_show -%}
          {%- assign lazy_load = false -%}
          {%- if forloop.index > 2 -%}
            {%- assign lazy_load = true -%}
          {%- endif -%}
          <li class="collection-ejire__item grid__item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'adapt',
              image_shape: 'default',
              lazy_load: lazy_load,
              show_secondary_image: true,
              show_vendor: false,
              show_rating: false,
              skip_styles: skip_card_product_styles,
              section_id: section.id,
              quick_add: 'none',
              skip_skeleton: true
            %}
          </li>
          {%- assign skip_card_product_styles = true -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..desktop_columns) -%}
          <li class="collection-ejire__item grid__item">
            <div class="card-wrapper product-card-wrapper underline-links-hover">
              <div class="card card--{{ settings.card_style }} card--media{% if settings.card_style == 'card' %} color-{{ settings.card_color_scheme }} gradient{% endif %} card--stacked-product">
                <div class="card__inner {% if settings.card_style == 'standard' %}color-{{ settings.card_color_scheme }} gradient{% endif %}">
                  <div class="card__media">
                    <div class="media media--transparent media--hover-effect">
                      <div class="collection-ejire__placeholder">
                        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</section>

<style>
  .collection-ejire__grid {
    margin-bottom: 0;
  }
  .collection-ejire__placeholder,
  .collection-ejire__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  .collection-ejire__placeholder .placeholder-svg {
    opacity: 0.3;
  }
  .collection-ejire__item .card__inner .card__media {
    aspect-ratio: 3 / 4;
  }
  .collection-ejire-{{ section.id }} .collection-ejire__item .product-card-wrapper,
  .collection-ejire-{{ section.id }} .collection-ejire__item .card--stacked-product,
  .collection-ejire-{{ section.id }} .collection-ejire__item .card__inner,
  .collection-ejire-{{ section.id }} .collection-ejire__item .card__inner .card__media {
    width: 100%;
    max-width: 100%;
  }
  .collection-ejire-{{ section.id }} .collection-ejire__item .card--stacked-product .card__inner {
    align-items: stretch;
  }
  .collection-ejire-{{ section.id }} .collection-ejire__item .card--stacked-product .card__inner .card__media {
    margin-left: 0;
    margin-right: 0;
  }
  @media screen and (max-width: 639px) {
    .collection-ejire-{{ section.id }} .collection-ejire__grid .grid__item {
      width: 100%;
    }
  }
  @media screen and (min-width: 640px) and (max-width: 1023px) {
    .collection-ejire-{{ section.id }} .collection-ejire__grid .grid__item {
      width: calc(50% - var(--grid-mobile-horizontal-spacing) / 2);
    }
  }
  @media screen and (min-width: 1024px) {
    .collection-ejire-{{ section.id }} .collection-ejire__grid .grid__item {
      width: calc({% if desktop_columns == 3 %}33.33% - var(--grid-desktop-horizontal-spacing) * 2 / 3{% else %}50% - var(--grid-desktop-horizontal-spacing) / 2{% endif %});
    }
  }
</style>

{% schema %}
{
  "name": "Collection 1 grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Fallback collection used when no product blocks are selected."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 5
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "options": [
        {
          "value": "2",
          "label": "2 columns"
        },
        {
          "value": "3",
          "label": "3 columns"
        }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 12,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection 1 grid",
      "blocks": [{ "type": "product" }, { "type": "product" }, { "type": "product" }]
    }
  ]
}
{% endschema %}

{%- style -%}
  .faq-grid-{{ section.id }} {
    padding-top: 8rem;
    padding-bottom: 8rem;
  }
{%- endstyle -%}

<section class="faq-grid faq-grid-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="faq-grid__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h1 class="faq-grid__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}

    <ul class="faq-grid__list" role="list">
      {%- if section.blocks.size > 0 -%}
        {%- assign faq_item_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'section_heading' -%}
            <li class="faq-grid__section-heading" {{ block.shopify_attributes }}>
              <h2 class="faq-grid__section-title">{{ block.settings.title | escape }}</h2>
            </li>
          {%- else -%}
            {%- assign faq_item_index = faq_item_index | plus: 1 -%}
            {%- assign item_id = 'faq-item-' | append: section.id | append: '-' | append: faq_item_index -%}
            <li class="faq-grid__item" {{ block.shopify_attributes }}>
              <input
                id="{{ item_id }}"
                class="faq-grid__input"
                type="radio"
                name="faq-{{ section.id }}"
                {% if section.settings.open_first and faq_item_index == 1 %}
                  checked
                {% endif %}
              >

              <label for="{{ item_id }}" class="faq-grid__question-row">
                <p class="faq-grid__question">{{ block.settings.question | escape }}</p>
                <svg
                  class="faq-grid__icon faq-grid__icon--chevron"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M5 8l5 5 5-5"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </label>

              <div class="faq-grid__answer-wrap">
                <div class="faq-grid__answer rte">
                  {{ block.settings.answer | escape | newline_to_br }}
                </div>
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Fallback when no blocks: matches Website FAQs copy; add blocks in theme editor for full sections. {%- endcomment -%}
        {%- assign default_faq_1_q = 'What is the difference between the Couture and Ready-to-Wear collections?' -%}
        {%- capture default_faq_1_a -%}Our Couture offering is made-to-measure, designed for bridal, occasion wear, and custom pieces created to your exact vision and measurements.

Our Ready-to-Wear collection is designed for immediate purchase, offering refined, thoughtfully constructed pieces for everyday and occasion dressing, with the same attention to detail and finish.{%- endcapture -%}
        {%- assign default_faq_2_q = 'Can I shop both brands on this website?' -%}
        {%- assign default_faq_2_a = 'Yes. This platform brings together both our couture and ready-to-wear offerings in one seamless experience.' -%}
        {%- assign default_faq_3_q = 'Do you offer custom designs?' -%}
        {%- assign default_faq_3_a = 'Yes. Custom and bespoke services are available under SheyeOladejo. You can book a consultation directly through our website.' -%}
        {%- assign default_faq_4_q = 'How do I place an order?' -%}
        {%- capture default_faq_4_a -%}Ready-to-wear pieces can be purchased directly online.

For custom or bridal orders, you will need to book a consultation before production begins.{%- endcapture -%}
        {%- assign default_faq_5_q = 'How long does production take?' -%}
        {%- capture default_faq_5_a -%}Production timelines vary depending on the piece:

• Ready-to-wear: Immediate or within a few days
• Custom pieces: Typically 2–6 weeks
• Bridal: Timelines will be communicated during consultation{%- endcapture -%}
        {%- assign default_faq_6_q = 'Do you ship internationally?' -%}
        {%- assign default_faq_6_a = 'Yes. We deliver within Nigeria and to international locations including the US, UK, and beyond.' -%}
        {%- for i in (1..6) -%}
          {%- assign item_id = 'faq-item-' | append: section.id | append: '-' | append: i -%}
          <li class="faq-grid__item">
            <input
              id="{{ item_id }}"
              class="faq-grid__input"
              type="radio"
              name="faq-{{ section.id }}"
              {% if section.settings.open_first and i == 1 %}
                checked
              {% endif %}
            >
            <label for="{{ item_id }}" class="faq-grid__question-row">
              <p class="faq-grid__question">
                {% case i -%}
                  {%- when 1 -%}
                    {{- default_faq_1_q -}}
                  {%- when 2 -%}
                    {{- default_faq_2_q -}}
                  {%- when 3 -%}
                    {{- default_faq_3_q -}}
                  {%- when 4 -%}
                    {{- default_faq_4_q -}}
                  {%- when 5 -%}
                    {{- default_faq_5_q -}}
                  {%- when 6 -%}
                    {{- default_faq_6_q -}}
                {%- endcase %}
              </p>
              <svg
                class="faq-grid__icon faq-grid__icon--chevron"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
              >
                <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </label>
            <div class="faq-grid__answer-wrap">
              <div class="faq-grid__answer rte">
                {%- case i -%}
                  {%- when 1 -%}
                    {{ default_faq_1_a | escape | newline_to_br }}
                  {%- when 2 -%}
                    {{ default_faq_2_a | escape | newline_to_br }}
                  {%- when 3 -%}
                    {{ default_faq_3_a | escape | newline_to_br }}
                  {%- when 4 -%}
                    {{ default_faq_4_a | escape | newline_to_br }}
                  {%- when 5 -%}
                    {{ default_faq_5_a | escape | newline_to_br }}
                  {%- when 6 -%}
                    {{ default_faq_6_a | escape | newline_to_br }}
                {%- endcase %}
              </div>
            </div>
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</section>

<style>
  /* Inner uses .page-width: inherit global max-width (1440px) + horizontal padding from base.css */
  .faq-grid__heading {
    margin: 0 0 2rem;
    font-family: var(--font-heading-family);
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    text-align: center;
  }
  .faq-grid__list {
    margin: 0;
    padding: 2rem 0;
    list-style: none;
  }
  .faq-grid__section-heading {
    list-style: none;
    margin: 0;
    padding: 2.5rem 0 1rem;
    border-bottom: none;
  }
  .faq-grid__section-heading:first-child {
    padding-top: 0;
  }
  .faq-grid__section-title {
    margin: 0;
    font-family: var(--font-heading-family);
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
  }
  .faq-grid__item {
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.2);
  }
  .faq-grid__input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .faq-grid__question-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    width: 100%;
    cursor: pointer;
    padding: 2rem 0;
  }
  .faq-grid__question {
    margin: 0;
    font-size: 1.05rem;
    color: rgb(var(--color-foreground));
  }
  .faq-grid__icon {
    width: 2rem;
    height: 2rem;
    color: rgb(var(--color-foreground));
    flex-shrink: 0;
  }
  .faq-grid__icon--chevron {
    color: rgb(var(--color-button));
    transition: transform 0.3s ease;
  }
  .faq-grid__input:checked + .faq-grid__question-row .faq-grid__icon--chevron {
    transform: rotate(180deg);
  }
  .faq-grid__answer-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  .faq-grid__answer {
    overflow: hidden;
    padding-right: 5rem;
    color: rgba(var(--color-foreground), 0.8);
    line-height: 1.7;
  }
  .faq-grid__answer p {
    margin: 0 0 1.2rem;
  }
  .faq-grid__input:checked ~ .faq-grid__answer-wrap {
    grid-template-rows: 1fr;
  }
  .faq-grid__input:checked ~ .faq-grid__answer-wrap .faq-grid__answer {
    padding-bottom: 2rem;
  }
</style>

{% schema %}
{
  "name": "FAQ accordion grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first item by default",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "section_heading",
      "name": "Section heading",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    },
    {
      "type": "item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "info": "Plain text. Separate paragraphs with a blank line. Line breaks within a paragraph are preserved."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion grid",
      "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }]
    }
  ]
}
{% endschema %}

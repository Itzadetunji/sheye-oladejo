{%- style -%}
  .faq-grid-{{ section.id }} {
    padding-top: 8rem;
    padding-bottom: 8rem;
  }
{%- endstyle -%}

<section class="faq-grid faq-grid-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="faq-grid__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h1 class="faq-grid__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}

    <ul class="faq-grid__list" role="list">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign item_id = 'faq-item-' | append: section.id | append: '-' | append: forloop.index -%}
          <li class="faq-grid__item" {{ block.shopify_attributes }}>
            <input
              id="{{ item_id }}"
              class="faq-grid__input"
              type="radio"
              name="faq-{{ section.id }}"
              {% if section.settings.open_first and forloop.first %}
                checked
              {% endif %}
            >

            <label for="{{ item_id }}" class="faq-grid__question-row">
              <p class="faq-grid__question">{{ block.settings.question | escape }}</p>
              <svg
                class="faq-grid__icon faq-grid__icon--chevron"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M5 8l5 5 5-5"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </label>

            <div class="faq-grid__answer-wrap">
              <div class="faq-grid__answer rte">
                {{ block.settings.answer }}
              </div>
            </div>
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Default FAQ content (from section liquid) when no blocks are added {%- endcomment -%}
        {%- assign default_faq_1_q = 'Do you offer international shipping?' -%}
        {%- capture default_faq_1_a -%}<p>Yes, we ship worldwide! Shipping costs will be added at checkout. We also offer discounts and promotions throughout the year, so keep an eye out for exclusive deals.</p><p><strong>Delivery times:</strong></p><ul><li>Lagos: 5-7 working days after payment confirmation.</li><li>International: 7-10 working days.</li></ul><p><strong>Custom orders:</strong></p><ul><li>Local: 7-10 working days.</li><li>International: 10-15 working days.</li></ul><p><strong>Express orders:</strong> For express orders, please email us to confirm availability before proceeding.</p>{%- endcapture -%}
        {%- assign default_faq_2_q = 'What is your payment policy?' -%}
        {%- capture default_faq_2_a -%}<ul><li>Orders are processed only after payment confirmation.</li><li>We accept bank transfers to our Naira, UK, US, and EUR accounts, as well as credit/debit card payments.</li></ul><p><strong>Bank account details:</strong></p><ul><li>NGN Account: SheyeOladejo Global Ventures, GTBANK, 0228230011</li><li>USD Account: SheyeOladejo Global Ventures, GTBANK, 0547249536</li><li>EUR Account: SheyeOladejo Global Ventures, GTBANK, 0547250358</li><li>GBP Account: SheyeOladejo Global Ventures, GTBANK, 0547250341</li></ul>{%- endcapture -%}
        {%- assign default_faq_3_q = 'Are your pieces true to size?' -%}
        {%- capture default_faq_3_a -%}<p>Some styles may run True-to-size / Run-Large / Run-Small. Please check product description or product specific size guide if there may be style specific size variation or you can also call customer care for sizing assistance.</p>{%- endcapture -%}
        {%- assign default_faq_4_q = 'Do you offer alterations for custom orders?' -%}
        {%- capture default_faq_4_a -%}<p>We highly recommend custom size clients to visit our studio for a fitting. If you can't make it, you can send us images or videos for a virtual fitting. Additional costs for custom order alterations are determined at drop-off.</p>{%- endcapture -%}
        {%- assign default_faq_5_q = 'What is your return policy?' -%}
        {%- capture default_faq_5_a -%}<p>We accept exchanges and offer store credit for full-priced items in good condition, returned within 5 working days of receipt.</p><ul><li>Customers bear the delivery cost for exchanges. Delivery charges are refundable only for faulty goods.</li><li>Refunds for damaged merchandise are processed within 3 business days.</li><li>All custom sizing sales are final.</li><li>All sales items are final.</li><li>Alterations for items approved after fittings are at the client's cost.</li></ul>{%- endcapture -%}
        {%- assign default_faq_6_q = 'What is your delivery policy?' -%}
        {%- capture default_faq_6_a -%}<p><strong>Processing time:</strong> Orders are processed within 1-2 business days. During sales and high-volume periods, processing may take 3-4 days.</p><p><strong>Shipping rates:</strong> Calculated at checkout based on your delivery location.</p><p><strong>Pre-order items:</strong> Processing begins on the date indicated in the product description.</p><p><strong>Dispatch notification:</strong> If you haven't received a dispatch notification within the specified time, email us at info@sheyeoladejo.com with your order number.</p><p><strong>Item not delivered?</strong></p><ul><li>Allow an extra 2-3 days before contacting us as packages may be delayed by the courier.</li><li>Refunds are not issued for lost packages, but items will be resent if a package cannot be traced.</li></ul><p><strong>Customs and duties:</strong> Duties and taxes are the customer's responsibility and vary by country.</p><p><strong>Pickups:</strong> Our Lagos office is open for pickups. We recommend this option for urgent orders.</p>{%- endcapture -%}
        {%- for i in (1..6) -%}
          {%- assign item_id = 'faq-item-' | append: section.id | append: '-' | append: i -%}
          <li class="faq-grid__item">
            <input
              id="{{ item_id }}"
              class="faq-grid__input"
              type="radio"
              name="faq-{{ section.id }}"
              {% if section.settings.open_first and i == 1 %}
                checked
              {% endif %}
            >
            <label for="{{ item_id }}" class="faq-grid__question-row">
              <p class="faq-grid__question">
                {% case i -%}
                  {%- when 1 -%}
                    {{- default_faq_1_q -}}
                  {%- when 2 -%}
                    {{- default_faq_2_q -}}
                  {%- when 3 -%}
                    {{- default_faq_3_q -}}
                  {%- when 4 -%}
                    {{- default_faq_4_q -}}
                  {%- when 5 -%}
                    {{- default_faq_5_q -}}
                  {%- when 6 -%}
                    {{- default_faq_6_q -}}
                {%- endcase %}
              </p>
              <svg
                class="faq-grid__icon faq-grid__icon--chevron"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
              >
                <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </label>
            <div class="faq-grid__answer-wrap">
              <div class="faq-grid__answer rte">
                {% case i -%}
                  {%- when 1 -%}
                    {{- default_faq_1_a -}}
                  {%- when 2 -%}
                    {{- default_faq_2_a -}}
                  {%- when 3 -%}
                    {{- default_faq_3_a -}}
                  {%- when 4 -%}
                    {{- default_faq_4_a -}}
                  {%- when 5 -%}
                    {{- default_faq_5_a -}}
                  {%- when 6 -%}
                    {{- default_faq_6_a -}}
                {%- endcase %}
              </div>
            </div>
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</section>

<style>
  /* Inner uses .page-width: inherit global max-width (1440px) + horizontal padding from base.css */
  .faq-grid__heading {
    margin: 0 0 2rem;
    font-family: var(--font-heading-family);
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    text-align: center;
  }
  .faq-grid__list {
    margin: 0;
    padding: 2rem 0;
    list-style: none;
  }
  .faq-grid__item {
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.2);
  }
  .faq-grid__input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .faq-grid__question-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    width: 100%;
    cursor: pointer;
    padding: 2rem 0;
  }
  .faq-grid__question {
    margin: 0;
    font-size: 1.05rem;
    color: rgb(var(--color-foreground));
  }
  .faq-grid__icon {
    width: 2rem;
    height: 2rem;
    color: rgb(var(--color-foreground));
    flex-shrink: 0;
  }
  .faq-grid__icon--chevron {
    color: rgb(var(--color-button));
    transition: transform 0.3s ease;
  }
  .faq-grid__input:checked + .faq-grid__question-row .faq-grid__icon--chevron {
    transform: rotate(180deg);
  }
  .faq-grid__answer-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  .faq-grid__answer {
    overflow: hidden;
    padding-right: 5rem;
    color: rgba(var(--color-foreground), 0.8);
    line-height: 1.7;
  }
  .faq-grid__answer p {
    margin: 0 0 1.2rem;
  }
  .faq-grid__input:checked ~ .faq-grid__answer-wrap {
    grid-template-rows: 1fr;
  }
  .faq-grid__input:checked ~ .faq-grid__answer-wrap .faq-grid__answer {
    padding-bottom: 2rem;
  }
</style>

{% schema %}
{
  "name": "FAQ accordion grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first item by default",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion grid",
      "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }]
    }
  ]
}
{% endschema %}

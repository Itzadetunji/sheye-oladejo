{%- liquid
  assign callout_heading = section.settings.callout_text | strip
  if callout_heading == blank
    assign callout_heading = 'Feel the Magic in Every Conversation'
  endif
-%}

{%- style -%}
  .book-consultation-callout-{{ section.id }} {
    min-height: 12rem;
    background: {{ settings.color_accent_porcelain | default: '#F3EDE8' }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .book-consultation-callout-{{ section.id }}__heading {
    margin: 0;
    font-size: clamp(1.9rem, 4.3vw, 3.5rem);
    font-family: "Times New Roman", Georgia, serif;
    font-style: italic;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    line-height: 1.2;
  }
{%- endstyle -%}

<section class="book-consultation-callout-{{ section.id }}">
  <h2 class="book-consultation-callout-{{ section.id }}__heading">
    {{ callout_heading | escape }}
  </h2>
</section>

{% schema %}
{
  "name": "Book consultation callout",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "callout_text",
      "label": "Callout text",
      "default": "Feel the Magic in Every Conversation"
    }
  ],
  "presets": [
    {
      "name": "Book consultation callout"
    }
  ]
}
{% endschema %}

{%- style -%}
  .collection-three-column-grid-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .collection-three-column-grid-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="collection-three-column-grid collection-three-column-grid-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="collection-three-column-grid__grid">
      {%- for block in section.blocks -%}
        <div class="collection-three-column-grid__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 960
              | image_tag:
                loading: 'lazy',
                class: 'collection-three-column-grid__image',
                sizes: '(min-width: 990px) 33vw, 100vw',
                widths: '375, 550, 750, 960, 1200'
            }}
          {%- else -%}
            <div class="collection-three-column-grid__placeholder">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .collection-three-column-grid__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .collection-three-column-grid__item {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }
  .collection-three-column-grid__image,
  .collection-three-column-grid__placeholder,
  .collection-three-column-grid__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  @media screen and (min-width: 768px) {
    .collection-three-column-grid__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>

{% schema %}
{
  "name": "Collection 3-column grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection 3-column grid",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
